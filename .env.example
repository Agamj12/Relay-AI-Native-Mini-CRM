# Optional — without it, Relay runs with deterministic AI fallbacks.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Database Configuration (defaults to local MongoDB if not set)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/relay

# Service wiring (defaults shown)
PORT=4000
CHANNEL_URL=http://localhost:4100
CRM_URL=http://localhost:4000
